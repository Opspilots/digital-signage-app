# ─── Backend ────────────────────────────────────────────────────────────────
# Port the backend API listens on inside the container (default: 3001)
PORT=3001

# Allowed CORS origin(s). Use '*' to allow all origins (dev only).
# For production set to the hostname serving the frontend, e.g.:
#   CORS_ORIGIN=http://192.168.1.100
CORS_ORIGIN=*

# Secret key for signing JWT tokens (future auth support).
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_before_production

# ─── Frontend (baked in at build time by Vite) ───────────────────────────────
# Full URL of the backend API reachable from the browser.
# In a LAN/kiosk setup this is the host machine's IP, e.g.:
#   VITE_API_URL=http://192.168.1.100:3001
VITE_API_URL=http://localhost:3001

# Title shown in the browser tab
VITE_APP_TITLE=Digital Signage
